# Copia este archivo como .env y rellena los valores reales
# NUNCA commitees .env — solo .env.example va al repo

# Firebase Web SDK (Firebase Console → Project Settings → General → Your Apps)
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# N8N Webhooks (N8N Cloud → Workflow → Webhook node → URL)
VITE_N8N_CHECKOUT_URL=https://your-n8n.app.n8n.cloud/webhook/checkout
VITE_N8N_ONBOARDING_URL=https://your-n8n.app.n8n.cloud/webhook/onboarding
